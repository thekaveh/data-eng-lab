    {
      "title": "4. Transform (code)",
      "text": "%spark\nspark.sql(\"UPDATE lakehouse.gold.dim_customer_scd2 SET effective_to = current_timestamp(), is_current = false WHERE customer_id = 'C1' AND is_current = true\").show(false)",
