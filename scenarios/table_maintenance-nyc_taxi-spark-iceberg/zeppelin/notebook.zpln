    {
      "title": "5. Write (code)",
      "text": "%spark\nspark.sql(\"CALL lakehouse.system.expire_snapshots(table => 'lakehouse.silver.nyc_taxi_tm', older_than => current_timestamp(), retain_last => 1)\").show(false)\nspark.sql(\"CALL lakehouse.system.remove_orphan_files(table => 'lakehouse.silver.nyc_taxi_tm')\").show(false)",
