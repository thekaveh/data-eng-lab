    },
    {
      "title": "4. Transform (code)",
      "text": "%spark\nspark.sql(\"CALL lakehouse.system.rewrite_data_files(table => 'lakehouse.silver.nyc_taxi_tm', options => map('target-file-size-bytes','134217728'))\").show(false)",
      "config": {},
      "settings": {
        "params": {},
