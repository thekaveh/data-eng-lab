    },
    {
      "title": "3. Read (code)",
      "text": "%spark\nspark.sql(\"CREATE TABLE IF NOT EXISTS lakehouse.silver.nyc_taxi_tm AS SELECT * FROM lakehouse.bronze.nyc_taxi_trips\").show(false)\nspark.sql(\"INSERT INTO lakehouse.silver.nyc_taxi_tm SELECT * FROM lakehouse.bronze.nyc_taxi_trips WHERE passenger_count > 3\").show(false)\nspark.sql(\"SELECT count(*) AS files FROM lakehouse.silver.nyc_taxi_tm.files\").show(false)",
      "config": {},
      "settings": {
        "params": {},
        "forms": {}
      }
