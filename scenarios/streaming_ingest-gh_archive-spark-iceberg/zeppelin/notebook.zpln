    {
      "title": "2. Setup (code)",
      "text": "%spark\nimport spark.implicits._\nimport org.apache.spark.sql.functions._\nimport org.apache.spark.sql.types._\n// spark is pre-bound by the Atlas Zeppelin interpreter",
      "config": {},
      "settings": {
